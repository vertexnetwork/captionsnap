NEXT_PUBLIC_SITE_URL=https://captionsnap.io
NEXT_PUBLIC_CLARITY_ID=

# Public GitHub repo. Surfaced on /changelog as "Full release notes on GitHub →".
# Leave empty to hide the link.
NEXT_PUBLIC_GITHUB_REPO_URL=

# Ad provider switch — Vertex Network spec §10. CaptionSnap is intentionally
# Pro-only; keep at "none".
NEXT_PUBLIC_AD_PROVIDER=none

# Single affiliate slot — Vertex Network spec §10. Provider not selected yet.
NEXT_PUBLIC_AFFILIATE_ENABLED=0
NEXT_PUBLIC_AFFILIATE_URL=
NEXT_PUBLIC_AFFILIATE_LABEL=
NEXT_PUBLIC_AFFILIATE_PROVIDER=

# Embed surface — Vertex Network spec §10. The /embed builder + preview are
# always reachable; this flag controls whether the generated snippet actually
# functions (i.e., whether /embed/render serves iframeable content). Default 1.
NEXT_PUBLIC_EMBED_ENABLED=1

# Pro tier (LemonSqueezy, Merchant of Record). Set NEXT_PUBLIC_PRO_ENABLED=true
# to expose /pricing and accept checkout.
NEXT_PUBLIC_PRO_ENABLED=false
# API key from LemonSqueezy → Settings → API. Used only for checkout creation
# and the customer-portal lookup; the license activate/validate calls are
# unauthenticated by design.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
# Variant IDs for the monthly / annual subscription products. The product MUST
# have "License keys" enabled with a sensible activation limit (e.g. 3) — that
# limit is what bounds key-sharing. Generate one license per order.
LEMONSQUEEZY_VARIANT_MONTHLY=
LEMONSQUEEZY_VARIANT_ANNUAL=
# Signing secret for the LemonSqueezy webhook (Settings → Webhooks). The
# webhook must subscribe to: license_key_created (required — triggers the
# license email) plus the subscription_* events (logged).
LEMONSQUEEZY_WEBHOOK_SECRET=

# Resend — sends the license-key email on purchase. Without it, purchases
# still work (the key shows on the LemonSqueezy receipt page) but no email
# is sent.
RESEND_API_KEY=
EMAIL_FROM="CaptionSnap <hello@captionsnap.io>"

# 32+ random bytes (any string). Signs the short-lived (1h) license token and
# the long-lived license cookie — must be identical across preview + prod or
# tokens/cookies issued in one env won't verify in the other.
LICENSE_HMAC_SECRET=

# Chrome extension Web Store listing URL (set after Web Store approval).
NEXT_PUBLIC_CHROME_WEBSTORE_URL=
