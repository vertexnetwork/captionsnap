NEXT_PUBLIC_SITE_URL=https://captionsnap.io
NEXT_PUBLIC_CLARITY_ID=

# Public GitHub repo. Surfaced on /changelog as "Full release notes on GitHub →".
# Leave empty to hide the link.
NEXT_PUBLIC_GITHUB_REPO_URL=

# Ad provider switch — Vertex Network spec §10. CaptionSnap is intentionally
# Pro-only; keep at "none".
NEXT_PUBLIC_AD_PROVIDER=none

# Single affiliate slot — Vertex Network spec §10. Provider not selected yet.
NEXT_PUBLIC_AFFILIATE_ENABLED=0
NEXT_PUBLIC_AFFILIATE_URL=
NEXT_PUBLIC_AFFILIATE_LABEL=
NEXT_PUBLIC_AFFILIATE_PROVIDER=

# Embed surface — Vertex Network spec §10. The /embed builder + preview are
# always reachable; this flag controls whether the generated snippet actually
# functions (i.e., whether /embed/render serves iframeable content). Default 1.
NEXT_PUBLIC_EMBED_ENABLED=1

# Pro tier (Stripe). Set NEXT_PUBLIC_PRO_ENABLED=true to expose /pricing.
NEXT_PUBLIC_PRO_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=
# 32+ random bytes (any string). Used to sign license tokens — must be
# identical across preview + prod or tokens issued in one env won't verify
# in the other.
LICENSE_HMAC_SECRET=

# Chrome extension Web Store listing URL (set after Web Store approval).
NEXT_PUBLIC_CHROME_WEBSTORE_URL=
